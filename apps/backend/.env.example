# === AI Provider (Required) ===
# Mistral AI — get an API key at https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-api-key

# === Web Search (Required) ===
# Tavily is purpose-built for RAG / Perplexity-style search
# Get a free API key at https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-api-key

# === Server ===
PORT=3001
NODE_ENV=development

# === LLM Configuration (Mistral) ===
# Options: mistral-small-latest, mistral-medium-latest, mistral-large-latest, ministral-8b-latest
LLM_MODEL=mistral-small-latest
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# === Search Configuration ===
SEARCH_MAX_RESULTS=10
SEARCH_INCLUDE_ANSWER=false
